# --- E-Mail-Versand für Anfrage-/Buchungsformular (Resend) ---
# Kostenlosen API-Key erstellen unter https://resend.com (Domain verifizieren empfohlen).
# Ohne Key läuft die Seite im Demo-Modus: Anfragen werden serverseitig geloggt statt versendet.
RESEND_API_KEY=

# Empfängeradresse für eingehende Anfragen (z. B. info@krebs-tanksysteme.de)
BOOKING_TO_EMAIL=info@krebs-tanksysteme.de

# Absenderadresse (muss in Resend als verifizierte Domain hinterlegt sein)
BOOKING_FROM_EMAIL=anfrage@krebs-tanksysteme.de

# Öffentliche Basis-URL der Seite (für SEO / Sitemap / OpenGraph)
NEXT_PUBLIC_SITE_URL=https://www.krebs-tanksysteme.de
