# ---------------------------------------------------------------------------
# Bauernhof zum Silberbergwerk – Umgebungsvariablen
# Kopiere diese Datei zu ".env.local" und trage die echten Werte ein.
# Die Seite funktioniert auch OHNE diese Werte (E-Mail-Versand ist dann inaktiv).
# ---------------------------------------------------------------------------

# SMTP-Zugangsdaten für automatische Reservierungs-Bestätigungen (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Absender & Restaurant-Postfach (erhält eine Kopie jeder Reservierung)
MAIL_FROM="Bauernhof zum Silberbergwerk <info@bauernhof-silberbergwerk.de>"
MAIL_TO=info@bauernhof-silberbergwerk.de

# Optionaler Google-Maps-Embed-API-Key. Ohne Key wird die kostenlose
# Embed-Variante ohne Key genutzt (funktioniert ebenfalls).
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
