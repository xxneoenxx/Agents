# Elmtech Verbundelemente GmbH – Umgebungsvariablen (alle optional)
# Kopiere zu ".env.local". Die Seite funktioniert auch ohne diese Werte.

# SMTP für automatische Rückruf-Bestätigungen
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Elmtech Verbundelemente <info@elmtech.de>"
MAIL_TO=info@elmtech.de

# Optionaler Google-Maps-Embed-Key (ohne Key wird die schlüssellose Variante genutzt)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
