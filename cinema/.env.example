# CineStar Chemnitz – Umgebungsvariablen (alle optional)
# Kopiere zu ".env.local". Die Seite funktioniert auch ohne diese Werte.

# SMTP für automatische Ticket-Bestätigungen
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="CineStar Chemnitz <tickets@cinestar-chemnitz.de>"
MAIL_TO=info@cinestar-chemnitz.de

# Optionaler Google-Maps-Embed-Key (ohne Key wird die schlüssellose Variante genutzt)
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
